# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/
*.tsbuildinfo

# Test coverage
coverage/
*.lcov
.nyc_output/

# Environment and config
.env
.env.local
.env.*.local
settings/
config/

# Logs
logs/
*.log

# Database
*.db
*.sqlite
*.sqlite3

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
tmp/
temp/
.tmp/

# Test artifacts (NOT tests/ directory — test files are part of the repo)
debug-*.js
debug-*.ts
demo-*.ts
continuity-*.js
verify-*.js
live-*.js
simple-*.ts
final-*.js

# Development files
STAGE*.md
task-phase-*.md
swarm-tasks/
.claude-flow/
# Ignore .claude but include hooks and skills for packaging
.claude/*
!.claude/hooks/
!.claude/skills/
.claude/settings.local.json
test-instructions-*.md
CLAUDE.md

# Scripts - exclude all except specifically allowlisted maintainer scripts
scripts/*
!scripts/postinstall.js
!scripts/postinstall-claude-md.js
!scripts/uninstall.js
!scripts/publish.sh
!scripts/check-publish.js

# Research / reference
.research/

# User-specific
.claude-recall.json
claude-recall.db*.tgz
claude-recall-*.tgz

# Editor/tool caches
.jest-cache/

# Auth records (e.g., MSAL/Azure AD tokens written into cwd by enterprise tools)
.ericai_authrecord
*_authrecord
.azure/

# Auto-generated skills (per-user/per-project — must never ship in npm publish)
.claude/skills/auto-*/

# External reference repos kept under ~/external-refs/
beads/
claude-flow/

# Per-machine settings (use `claude-recall setup` to regenerate)
.claude/settings.json
